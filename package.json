{
  "name": "colorlab-embed",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Shoppal記事埋め込み用に自己完結ビルドしたパーソナルカラー診断アプリ(v19)とNG色警察",
  "scripts": {
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.mkdirSync('dist',{recursive:true})\"",
    "build:colorlab": "vite build --config vite.colorlab.config.mjs",
    "build:ngpolice": "vite build --config vite.ngpolice.config.mjs",
    "build": "npm run clean && npm run build:colorlab && npm run build:ngpolice",
    "verify": "node test/screenshot.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.49.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}
